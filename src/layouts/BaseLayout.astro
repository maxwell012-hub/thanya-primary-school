---
// src/layouts/BaseLayout.astro
// Generated by MaxG Site Manager — do not edit manually
import company from '../../content/company.json';
import seo from '../../content/seo.json';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = seo.defaultTitle,
  description = seo.defaultDescription,
  ogImage = seo.ogImage,
  noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="MaxG Site Manager" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={seo.siteUrl + ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={seo.locale} />

    <!-- Favicon -->
    <link rel="icon" href={company.favicon} />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <!-- Theme -->
    <meta name="theme-color" content={seo.themeColor} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0"
/>

    <slot name="head" />
  </head>

  <body>
    <!-- Generated by MaxG Site Manager | maxgen.site -->
    <slot name="header">
      <header class="site-header" id="site-header">
        <div class="container header-inner">
          <a href="/" class="site-logo" aria-label={company.name + ' Home'}>
            <img src={company.logo} alt={company.name} width="140" height="40" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
            <span class="logo-text" style="display:none">{company.name}</span>
          </a>
          <nav class="site-nav" aria-label="Main navigation">
            <ul class="nav-list">
              <li><a href="/" class="nav-link">Home</a></li>
              <li><a href="/about" class="nav-link">About</a></li>
              <li><a href="/services" class="nav-link">Services</a></li>
              <li><a href="/gallery" class="nav-link">Gallery</a></li>
              <li><a href="/contact" class="nav-link nav-cta">Contact Us</a></li>
            </ul>
          </nav>
          <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>
      </header>
    </slot>

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer">
      <footer class="site-footer">
        <div class="container footer-inner">
          <div class="footer-brand">
            <a href="/" class="site-logo footer-logo">
              <img src={company.logo} alt={company.name} width="120" height="36" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
              <span class="logo-text" style="display:none">{company.name}</span>
            </a>
            <p class="footer-tagline">{company.tagline}</p>
          </div>
          <div class="footer-links">
            <div class="footer-col">
              <h4 class="footer-heading">Navigation</h4>
              <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/gallery">Gallery</a></li>
                <li><a href="/contact">Contact</a></li>
              </ul>
            </div>
            <div class="footer-col">
              <h4 class="footer-heading">Contact</h4>
              <ul class="footer-contact-list">
                <li>
                  <a href={`tel:${company.phone}`}>{company.phone}</a>
                </li>
                <li>
                  <a href={`mailto:${company.email}`}>{company.email}</a>
                </li>
                <li>{company.address.city}, {company.address.province}</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <div class="container footer-bottom-inner">
            <p>© {new Date().getFullYear()} {company.name}. All rights reserved.</p>
            <p class="footer-attribution">
              Website by <a href="https://maxgen.site" target="_blank" rel="noopener">MaxG Studio</a>
            </p>
          </div>
        </div>
      </footer>
    </slot>

    <script>
      // Mobile navigation toggle
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('.site-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          nav.classList.toggle('nav-open', !expanded);
          toggle.classList.toggle('is-active', !expanded);
        });
      }

      // Sticky header on scroll
      const header = document.getElementById('site-header');
      if (header) {
        let lastScroll = 0;
        window.addEventListener('scroll', () => {
          const y = window.scrollY;
          header.classList.toggle('header-scrolled', y > 60);
          lastScroll = y;
        }, { passive: true });
      }

      // Active nav link
      const links = document.querySelectorAll('.nav-link');
      links.forEach(link => {
        if (link.getAttribute('href') === window.location.pathname) {
          link.classList.add('is-active');
        }
      });
    </script>
  </body>
</html>
