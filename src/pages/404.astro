---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import company from '../../content/company.json';
---

<BaseLayout title="Page Not Found | {company.name}" noindex={true}>
  <div style="
    min-height: 80vh;
    padding-top: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  ">
    <div class="container">
      <div style="font-size: 6rem; line-height: 1; margin-bottom: 1.5rem;">🔍</div>
      <h1 style="font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 800; margin-bottom: 1rem; letter-spacing: -0.03em;">
        Page Not Found
      </h1>
      <p style="color: var(--color-text-muted); font-size: var(--text-lg); max-width: 44ch; margin: 0 auto 2rem;">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn-primary btn-lg">Go Home</a>
        <a href="/contact" class="btn btn-outline btn-lg">Contact Us</a>
      </div>
    </div>
  </div>
</BaseLayout>
