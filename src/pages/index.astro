---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import company from '../../content/company.json';
import homePage from '../../content/pages/home.json';
import services from '../../content/services.json';
import testimonials from '../../content/testimonials.json';
import seo from '../../content/seo.json';
---

<BaseLayout 
  title={seo.pages.home.title}
  description={seo.pages.home.description}
>
  <!-- Hero -->
  <section class="hero">
    {homePage.hero.backgroundImage && (
      <div 
        class="hero-bg" 
        style={`background-image: url('${homePage.hero.backgroundImage}')`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container">
      <div class="hero-content">
        <span class="hero-label">{company.name}</span>
        <h1 class="hero-headline">{homePage.hero.headline}</h1>
        <p class="hero-subheadline">{homePage.hero.subheadline}</p>
        <div class="hero-actions">
          <a href={homePage.hero.ctaPrimary.href} class="btn btn-accent btn-lg">
            {homePage.hero.ctaPrimary.label}
          </a>
          <a href={homePage.hero.ctaSecondary.href} class="btn btn-ghost btn-lg">
            {homePage.hero.ctaSecondary.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  {homePage.showStats && (
    <div class="stats-bar">
      <div class="container">
        <div class="stats-grid">
          {homePage.stats.map((stat: {value: string; label: string}, i: number) => {
            const match = stat.value.match(/^([\d.]+)(.*)$/);
            const numeric = match ? match[1] : null;
            const suffix = match ? match[2] : '';
            return (
              <div class={`stat-item reveal reveal-delay-${Math.min(i + 1, 6)}`}>
                {numeric ? (
                  <div class="stat-value" data-count={numeric} data-suffix={suffix}>0{suffix}</div>
                ) : (
                  <div class="stat-value">{stat.value}</div>
                )}
                <div class="stat-label">{stat.label}</div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- Services Preview -->
  {homePage.featuredServices && (
    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <span class="section-label">What We Offer</span>
          <h2 class="section-title">{services.headline}</h2>
          <p class="section-subtitle">{services.subheadline}</p>
        </div>
        <div class="services-grid">
          {services.services.slice(0, 3).map((service: {image: string; title: string; description: string; price: string}, i: number) => (
            <div class={`service-card reveal reveal-delay-${i + 1}`}>
              <div class="service-image"><img src={service.image} alt={service.title} loading="lazy" /></div>
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.description}</p>
              <span class="service-price">{service.price}</span>
            </div>
          ))}
        </div>
        <div class="reveal" style="text-align: center; margin-top: 3rem;">
          <a href="/services" class="btn btn-primary btn-lg">View All Academics</a>
        </div>
      </div>
    </section>
  )}

  <!-- Events Teaser -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Stay Connected</span>
        <h2 class="section-title">Recent School Events</h2>
        <p class="section-subtitle">See what's been happening across our three campuses</p>
      </div>
      <div class="reveal" style="text-align: center;">
        <a href="/events" class="btn btn-primary btn-lg">View Events</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  {homePage.featuredTestimonials && (
    <section class="section">
      <div class="container">
        <div class="section-header reveal">
          <span class="section-label">Client Feedback</span>
          <h2 class="section-title">{testimonials.headline}</h2>
          <p class="section-subtitle">{testimonials.subheadline}</p>
        </div>
        <div class="testimonials-grid">
          {testimonials.testimonials.slice(0, 3).map((t: {rating: number; text: string; name: string; company: string; avatar: string}, i: number) => (
            <div class={`testimonial-card reveal reveal-delay-${i + 1}`}>
              <div class="testimonial-stars">{'★'.repeat(t.rating)}</div>
              <p class="testimonial-text">"{t.text}"</p>
              <div class="testimonial-author">
                <div class="testimonial-avatar">
                  {t.avatar 
                    ? <img src={t.avatar} alt={t.name} width="44" height="44" />
                    : t.name.charAt(0)
                  }
                </div>
                <div>
                  <div class="testimonial-name">{t.name}</div>
                  <div class="testimonial-company">{t.company}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal">
      <span class="section-label" style="color: var(--color-accent);">Ready to join us?</span>
      <h2 class="section-title">Give Your Child a Strong Start</h2>
      <p class="section-subtitle">
        Apply today or visit one of our three campuses to learn more about {company.name}.
      </p>
      <div class="cta-actions">
        <a href="/admissions" class="btn btn-accent btn-lg">Apply Now</a>
        <a href="tel:{company.phone}" class="btn btn-ghost btn-lg">
          📞 {company.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
