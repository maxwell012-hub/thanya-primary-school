---
// src/pages/admissions.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import admissionsData from '../../content/admissions.json';
import seo from '../../content/seo.json';
---

<BaseLayout
  title={seo.pages.admissions.title}
  description={seo.pages.admissions.description}
>
  <div class="page-hero">
    <div class="container">
      <h1>{admissionsData.headline}</h1>
      <p>{admissionsData.subheadline}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <p class="admissions-intro reveal">{admissionsData.intro}</p>

      <div class="download-card reveal">
        <div class="download-card-text">
          <h3>{admissionsData.formLabel}</h3>
          <p>Download, print, and complete the form, then submit it to your nearest campus office.</p>
        </div>
        <a
          href={admissionsData.formFile}
          download
          class="btn btn-download btn-lg"
        >
          ⬇ Download Form
        </a>
      </div>

      <h2 class="reveal" style="font-family: var(--font-display); font-size: var(--text-2xl); margin-bottom: 1.5rem;">
        How to Apply
      </h2>
      <div class="steps-grid">
        {admissionsData.steps.map((step, i) => (
          <div class={`step-card reveal reveal-delay-${i + 1}`}>
            <div class="step-number">{i + 1}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
        ))}
      </div>

      <div class="documents-card reveal">
        <h3>Required Documents</h3>
        <ul class="documents-list">
          {admissionsData.requiredDocuments.map((doc) => (
            <li>
              <span style="color: var(--color-primary); font-weight: 700;">✓</span>
              <span>{doc}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
