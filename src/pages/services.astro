---
// src/pages/services.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import services from '../../content/services.json';
import company from '../../content/company.json';
import seo from '../../content/seo.json';
---

<BaseLayout
  title={seo.pages.services.title}
  description={seo.pages.services.description}
>
  <div class="page-hero">
    <div class="container">
      <h1>{services.headline}</h1>
      <p>{services.subheadline}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {services.services.map((service: {image: string; title: string; description: string; price: string}) => (
  <div class="service-card">
    <div class="service-image">
      <img src={service.image} alt={service.title} loading="lazy" />
    </div>

    <h3 class="service-title">{service.title}</h3>
    <p class="service-desc">{service.description}</p>
    <span class="service-price">{service.price}</span>
  </div>
))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <span class="section-label" style="color: var(--color-accent);">Interested?</span>
      <h2 class="section-title">Request a Quote Today</h2>
      <p class="section-subtitle">
        Contact us and one of our team members will get back to you promptly.
      </p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-accent btn-lg">Get a Free Quote</a>
        <a href="tel:{company.phone}" class="btn btn-ghost btn-lg">📞 Call Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
